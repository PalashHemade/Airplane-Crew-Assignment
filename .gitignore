# ──────────────────────────────────────────────
# .gitignore — Branch & Bound Visualizer (Next.js)
# ──────────────────────────────────────────────

# ── Dependencies ───────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ───────────────────────
/.next/
/out/
/build/

# ── TypeScript ─────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Environment variables ──────────────────────
# Never commit secrets!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ── Testing / coverage ─────────────────────────
/coverage
/.nyc_output

# ── Debug & logs ───────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log

# ── OS-generated files ─────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ── Editor / IDE ───────────────────────────────
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# ── Deployment ─────────────────────────────────
.vercel
.netlify

# ── Misc ───────────────────────────────────────
*.pem
*.key
*.cert
